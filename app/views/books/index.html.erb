<h1>Book Store</h1>
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; gap: 16px;">
    <div style="display: flex; align-items: center; gap: 8px;">
        <span style="font-size: 1.3em; font-weight: 600; color: #222;">📚 All Books</span>
        <span style="background: #f1f3f4; color: #555; font-size: 0.95em; padding: 2px 10px; border-radius: 12px;">
            <%= @books.size %>
        </span>
    </div>
    <%= link_to new_book_path, class: "btn", style: "display: flex; align-items: center; gap: 6px; padding: 9px 18px; background: linear-gradient(90deg,#007bff 60%,#0056b3 100%); color: #fff; border-radius: 6px; font-weight: 500; box-shadow: 0 2px 8px rgba(0,123,255,0.08); text-decoration: none; border: none;" do %>
        <span style="font-size: 1.1em;">➕</span>
        <span>New Book</span>
    <% end %>
</div>
<hr>
 


<div class="row">
    <% @books.each do |book| %>
        <div class="card mb-3" style="width: 100%; max-width: 400px; margin: 0 auto 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); border-radius: 8px; padding: 16px;">
            <div class="card-body">
                <h5 class="card-title" style="margin-bottom: 8px;">
                    <a href="<%= book_path(book) %>" style="text-decoration: none; color: #007bff;">
                        <%= book.name %>
                    </a>
                </h5>
                <p class="card-text" style="color: #555; margin-bottom: 0;">
                    <strong>ISBN:</strong> <%= book.isbn %>
                </p>
            </div>
        </div>
    <% end %>
</div>
