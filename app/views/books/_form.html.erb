<style>
    .book-form-container {
        max-width: 400px;
        margin: 40px auto;
        padding: 32px 24px;
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.08);
        font-family: 'Segoe UI', Arial, sans-serif;
    }
    .book-form-container h2 {
        text-align: center;
        margin-bottom: 24px;
        color: #2d3748;
        font-size: 1.6rem;
        font-weight: 600;
    }
    .book-form-container label {
        display: block;
        margin-bottom: 8px;
        color: #4a5568;
        font-size: 1rem;
        font-weight: 500;
    }
    .book-form-container input[type="text"] {
        width: 100%;
        padding: 10px 12px;
        border: 1px solid #cbd5e0;
        border-radius: 6px;
        font-size: 1rem;
        margin-bottom: 18px;
        transition: border-color 0.2s;
    }
    .book-form-container input[type="text"]:focus {
        border-color: #3182ce;
        outline: none;
    }
    .book-form-container input[type="submit"] {
        width: 100%;
        padding: 12px;
        background: #3182ce;
        color: #fff;
        border: none;
        border-radius: 6px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
    }
    .book-form-container input[type="submit"]:hover {
        background: #2563eb;
    }
</style>
<div class="book-form-container">
    <h2><%= book.new_record? ? "Add New Book" : "Edit Book" %></h2>
<%= form_with model: book do |form| %>
  <div>
    <%= form.label :name %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>

